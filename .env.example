# Real estate prediction application - Environment Configuration Template
# 
# ⚠️ SECURITY WARNING ⚠️
# This is an EXAMPLE file for reference only.
# DO NOT commit .env file with real secrets to git!
# 
# Usage:
# 1. Copy this file: cp .env.example .env
# 2. Fill in your actual secrets in .env
# 3. The real .env is protected by .gitignore
#
# See k3s/GITHUB_ACTIONS_SETUP.md for GitHub Secrets setup

# Hugging Face API token for model access
HF_API_KEY=your_huggingface_token_here

# Mistral API key for LLM access
MISTRAL_API_KEY=your_mistral_api_key_here

# LangSmith tracing configuration
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://eu.api.smith.langchain.com
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=your_project_name_here

# MCP Server configuration (for K3S deployment)
MCP_SERVER_HOST=localhost
MCP_SERVER_PORT=8001

# Optional: Service ports (local development)
FASTAPI_PORT=8000
GRADIO_PORT=7860

# Note:
# - .env is NOT committed to git (see .gitignore)
# - GitHub Secrets used for CI/CD deployments
# - Never paste real secrets in documentation or code
